{
  "name": "@workspace/api-server",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --testTimeout 15000"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.23",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "argon2": "^0.44.0",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "openai": "^4.0.0",
    "pdfkit": "^0.15.2",
    "pino": "^9",
    "pino-http": "^10",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "vitest": "^4.1.10"
  }
}
